# ============ SERVEUR ============
PORT=5000
NODE_ENV=development

# ============ BASE DE DONNÉES ============
MONGO_URI=mongodb://localhost:27017/universite_moundou

# ============ SÉCURITÉ ============
JWT_SECRET=U2FsdGVkX1+universite_moundou_2025_secret_key_très_long_et_sécurisé
JWT_EXPIRE=7d

# ============ AIRTEL MONEY API ============
# Environnement Sandbox (Test)
AIRTEL_API_BASE_URL=https://openapiuat.airtel.africa
CLIENT_ID=votre_client_id_ici
CLIENT_SECRET=votre_client_secret_ici
GRANT_TYPE=client_credentials
COUNTRY=TD
CURRENCY=XAF
AIRTEL_API_VERSION=1

# Environnement Production (décommenter après validation)
# AIRTEL_API_BASE_URL=https://openapi.airtel.africa
# CLIENT_ID=votre_client_id_production
# CLIENT_SECRET=votre_client_secret_production

# ============ MOOV MONEY API ============
MOOV_API_BASE_URL=https://api.moov.td/v1
MOOV_CLIENT_ID=votre_moov_client_id
MOOV_CLIENT_SECRET=votre_moov_client_secret
MOOV_SUBSCRIPTION_KEY=votre_subscription_key

# ============ EMAIL (Gmail) ============
# Pour obtenir un mot de passe d'application :
# 1. Activer validation en deux étapes sur votre compte Gmail
# 2. Aller sur https://myaccount.google.com/apppasswords
# 3. Générer un mot de passe pour "Application personnalisée"
EMAIL_USER=admissions@univ-moundou.td
EMAIL_PASS=xxxx xxxx xxxx xxxx  # 16 caractères avec espaces

# ============ ADMIN UNIQUE ============
# ⚠️ UN SEUL super_admin peut exister - ces identifiants sont uniques
ADMIN_EMAIL=admin@univ-moundou.td
ADMIN_PASSWORD=Admin123456
# ⚠️ Changez ce mot de passe en production !